# ─── BACKEND ─────────────────────────────────────────────
# PostgreSQL connection string from Supabase
# Get from: Supabase → Project Settings → Database → URI
DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# OpenRouter API key (free at openrouter.ai)
OPENROUTER_API_KEY=sk-or-v1-...

# The URL of your deployed channel stub service
CHANNEL_STUB_URL=http://localhost:8001

# A random secret (generate with: openssl rand -hex 32)
SECRET_KEY=your-secret-key-here

# Time compression: divides all simulation delays by this factor
# 60 = 30min real-time becomes 30sec in demo
TIME_COMPRESSION_FACTOR=60

# CORS — add your frontend URL here when deployed
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app

ENVIRONMENT=development

# ─── CHANNEL STUB ─────────────────────────────────────────
# The URL of your deployed CRM backend
CRM_RECEIPT_URL=http://localhost:8000/api/v1/receipts

# Must match TIME_COMPRESSION_FACTOR above
TIME_COMPRESSION_FACTOR=60

# ─── FRONTEND ─────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
